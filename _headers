# HTTP Headers Configuration
# Format: Netlify-compatible, also works on Cloudflare Pages
# Last updated: 2026-05-15

# ===== GLOBAL SECURITY HEADERS =====
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://unpkg.com https://app.cal.com https://cal.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://api.github.com https://*.cal.com https://api.web3forms.com; frame-src https://www.google.com https://cal.com https://app.cal.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://api.web3forms.com

# ===== HTML PAGES - Luôn fresh =====
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# ===== CSS - Cache 1 ngày (KHÔNG immutable để dễ update) =====
/css/*
  Cache-Control: public, max-age=86400, must-revalidate
  X-Content-Type-Options: nosniff

# ===== JS - Cache 1 ngày =====
/js/*
  Cache-Control: public, max-age=86400, must-revalidate

# ===== IMAGES - Cache 30 ngày (ít thay đổi) =====
/images/*
  Cache-Control: public, max-age=2592000

/*.svg
  Cache-Control: public, max-age=2592000
  Content-Type: image/svg+xml

/*.jpg
  Cache-Control: public, max-age=2592000

/*.png
  Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000

# ===== FAVICONS =====
/favicon.ico
  Cache-Control: public, max-age=86400
  Content-Type: image/x-icon

/favicon.svg
  Cache-Control: public, max-age=86400
  Content-Type: image/svg+xml

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# ===== SITEMAP & ROBOTS =====
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/site.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json
